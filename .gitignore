.env
__pycache__/
*.pyc
venv/
.DS_Store
# NOTE: market_snapshot.json is intentionally NOT ignored — market_data.yml
# commits it (git add market_snapshot.json) as the cloud routine's data source.
fills.json
performance_report.json
# Forecast ledger (#2) — local observational data, regenerated each run.
forecasts.jsonl
forecasts_scored.jsonl
agent_scorecards.json
# Analysis / recovery artifacts — regenerated from logs on demand.
deliberation_stats.json
reconciliation_report.json
# A12 reproducibility manifest + exported prompts (regenerated each run from
# analysis.py constants) and B16 append-only health history.
reproducibility.json
prompts/
health_history.jsonl
# FMP provider cache (#1) — persisted in CI via actions/cache, transient locally.
provider_cache.json

# Portfolio & trade data — contains real positions, cost bases, order IDs.
# The routine commits these via explicit git add; they are intentionally NOT
# tracked here so a public repo does not expose financial data.
mcp_portfolio.json
mcp_market_data.json
portfolio_snapshot.json
portfolio_peak.json
pending_decisions.json
trades.csv
transactions.json
decision_journal.json
agent_log.json
system_health.json
fundamentals_cache.json
